                # Evaluar la mejor jugada para la pieza actual
                if usar_estrategia_rapida:
                    punt_actual, col_objetivo, rot_objetivo = mejor_placement_rapido(matriz_tablero, pieza_actual, nivel)
                else:
                    punt_actual, col_objetivo, rot_objetivo = mejor_placement(matriz_tablero, pieza_actual)

                puede_colocar_actual = col_objetivo is not None

                # Inicializar variables para la opción de hold
                punt_hold = float('-inf')
                hold_accion = None   # 'guardar' o 'swap'

                # Si no hemos usado hold recientemente, evaluamos opciones
                if not ultimo_hold_usado:
                    # Opción 1: Hold vacío -> guardar pieza actual y usar la siguiente
                    if pieza_en_hold is None:
                        if proximas_piezas:  # hay al menos una siguiente
                            nueva_pieza = proximas_piezas[0]
                            # Simular guardar: la pieza actual se guarda, la nueva es la siguiente
                            if usar_estrategia_rapida:
                                punt_sig, col_sig, rot_sig = mejor_placement_rapido(matriz_tablero, nueva_pieza, nivel)
                            else:
                                punt_sig, col_sig, rot_sig = mejor_placement(matriz_tablero, nueva_pieza)
                            if col_sig is not None:
                                # Simular la colocación de la nueva pieza
                                nuevo_tablero, lineas = simular_placement(matriz_tablero, nueva_pieza, rot_sig, col_sig)
                                punt_hold = puntuar_tablero(nuevo_tablero, lineas)
                                hold_accion = 'guardar'
                    # Opción 2: Hay pieza en hold -> intercambiar
                    else:
                        nueva_pieza = pieza_en_hold
                        if usar_estrategia_rapida:
                            punt_swap, col_swap, rot_swap = mejor_placement_rapido(matriz_tablero, nueva_pieza, nivel)
                        else:
                            punt_swap, col_swap, rot_swap = mejor_placement(matriz_tablero, nueva_pieza)
                        if col_swap is not None:
                            nuevo_tablero, lineas = simular_placement(matriz_tablero, nueva_pieza, rot_swap, col_swap)
                            punt_hold = puntuar_tablero(nuevo_tablero, lineas)
                            hold_accion = 'swap'

                # Decisión: comparar puntuaciones
                if puede_colocar_actual and (punt_actual >= punt_hold):
                    # Colocar la pieza actual
                    _, lineas_eliminadas = simular_placement(matriz_tablero, pieza_actual, rot_objetivo, col_objetivo)
                    lineas_totales += lineas_eliminadas
                    exito = colocar_pieza_mejorada(pieza_actual, columna_spawn, col_objetivo, rot_objetivo,
                                                    keyboard, spawn_region, cell_w, nivel, usar_estrategia_rapida)
                    if exito:
                        ultimo_hold_usado = False
                    else:
                        contador_fallos += 1
                    pieza_actual = None

                elif hold_accion is not None:
                    # Ejecutar hold (guardar o intercambiar)
                    keyboard.press(Key.shift)
                    time.sleep(0.05 if not usar_estrategia_rapida else 0.03)
                    keyboard.release(Key.shift)
                    ultimo_hold_usado = True
                    pieza_actual = None
                    time.sleep(0.3 if not usar_estrategia_rapida else 0.15)

                else:
                    # No hay opción válida, esperar
                    pieza_actual = None
